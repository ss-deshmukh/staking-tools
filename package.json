{
  "name": "staking-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Polkadot staking-async tools — validator APY calculator and more, served as a static site",
  "scripts": {
    "snapshot": "tsx validator/cli/snapshot.ts",
    "apy": "tsx validator/cli/apy.ts",
    "embed": "tsx validator/cli/embed.ts > validator/web/data.json",
    "build-web": "tsx validator/cli/embed.ts > validator/web/data.json && tsx validator/cli/build-web.ts",
    "build-expenses": "tsx expenses/cli/build-web.ts",
    "build-kusama": "tsx kusama/cli/build-web.ts",
    "health-reconstruct": "tsx health/cli/reconstruct.ts",
    "build-health": "tsx health/cli/embed.ts > health/web/data.json && tsx health/cli/build-web.ts",
    "build-site": "tsx tools/build-site.ts",
    "test": "tsx --test validator/test/*.test.ts",
    "papi": "papi",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "polkadot-api": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
