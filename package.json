{
  "name": "staking-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Snapshot + APY tooling for Polkadot staking-async (DAP mode) on Asset Hub chains",
  "scripts": {
    "snapshot": "tsx validator/cli/snapshot.ts",
    "apy": "tsx validator/cli/apy.ts",
    "embed": "tsx validator/cli/embed.ts > validator/web/data.json",
    "build-web": "tsx validator/cli/embed.ts > validator/web/data.json && tsx validator/cli/build-web.ts",
    "test": "tsx --test validator/test/*.test.ts",
    "papi": "papi",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "polkadot-api": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
